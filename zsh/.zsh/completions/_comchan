#compdef comchan

autoload -U is-at-least

_comchan() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--completions=[Generate Shell completions]:COMPLETIONS:(bash zsh fish elvish power-shell nu)' \
'-p+[Serial port to connect to]:PORT:_default' \
'--port=[Serial port to connect to]:PORT:_default' \
'-r+[Baud Rate of the Serial Monitor]:BAUD:_default' \
'--baud=[Baud Rate of the Serial Monitor]:BAUD:_default' \
'-d+[]:DATA_BITS:_default' \
'--data-bits=[]:DATA_BITS:_default' \
'-s+[]:STOP_BITS:_default' \
'--stop-bits=[]:STOP_BITS:_default' \
'--parity=[]:PARITY:_default' \
'--flow-control=[]:FLOW_CONTROL:_default' \
'-t+[]:TIMEOUT_MS:_default' \
'--timeout=[]:TIMEOUT_MS:_default' \
'--reset-delay=[]:RESET_DELAY_MS:_default' \
'-l+[Log Serial data into a file]:LOG_FILE:_default' \
'--log=[Log Serial data into a file]:LOG_FILE:_default' \
'--plot-points=[]:PLOT_POINTS:_default' \
'-c+[Path to config file]:CONFIG_FILE:_files' \
'--config=[Path to config file]:CONFIG_FILE:_files' \
'--export-limit=[Max points to keep in memory for export per sensor]:EXPORT_LIMIT:_default' \
'--plot-title=[Set the plot title for the exported SVG file]:PLOT_TITLE:_default' \
'--csv=[Export numeric data to a CSV file while streaming serial data]:CSV_FILE:_default' \
'--replay=[Replay a previous session from its *.log or *.csv file]:REPLAY_FILE:_default' \
'--obj=[Path to .obj file]:OBJ_FILE:_default' \
'--braille=[Select a built-in Braille 3D model (cube, tetrahedron, octahedron) or provide a path to a custom .wrfm file]:BRAILLE:_default' \
'--list-ports[List all available ports]' \
'--auto[Auto-detect USB serial port]' \
'-v[]' \
'--verbose[]' \
'--plot[Launch the serial plotter]' \
'--generate-config[]' \
'--zephyr[Enables Zephyr Shell mode]' \
'--simulate[Simulate Serial Data with no need for hardware (Use for testing ComChan)]' \
'-x[Display incoming serial data in hex dump format]' \
'--hex[Display incoming serial data in hex dump format]' \
'--hex-pretty[Display incoming serial data in a clean, buffered hex-dump format]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
}

(( $+functions[_comchan_commands] )) ||
_comchan_commands() {
    local commands; commands=()
    _describe -t commands 'comchan commands' commands "$@"
}

if [ "$funcstack[1]" = "_comchan" ]; then
    _comchan "$@"
else
    compdef _comchan comchan
fi
